{
    "files.associations": {
        "*.yaml": "home-assistant"
    },
    "actionButtons": {
        "defaultColor": "#ffffff", // Default color for buttons (optional)
        "loadNpmCommands": false, // Disable automatic npm commands
        "commands": [
            {
                "name": "▶️ Start HA USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "green",
                "command": "ha apps start local_ha_usbip_client"
            },
            {
                "name": "🛑 Stop HA USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "red",
                "command": "ha apps stop local_ha_usbip_client"
            },
            {
                "name": "🔄 Restart HA USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "blue",
                "command": "ha apps restart local_ha_usbip_client"
            },
            {
                "name": "🛠️ Rebuild HA USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "orange",
                "command": "ha apps rebuild local_ha_usbip_client"
            },
            {
                "name": "📜 Logs HA USBIP (follow)",
                "singleInstance": true,
                "focus": true,
                "color": "purple",
                "command": "ha apps logs local_ha_usbip_client --follow"
            }
        ]
    },

    // NOTE: Configure `extraPaths` in `pyrightconfig.json` (do not set
    // `python.analysis.extraPaths` here when `pyrightconfig.json` is present)
    "python.defaultInterpreterPath": "/usr/bin/python3"
}
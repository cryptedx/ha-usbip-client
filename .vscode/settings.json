{
    "files.associations": {
        "*.yaml": "home-assistant"
    },
    "actionButtons": {
        "defaultColor": "#ffffff", // Default color for buttons (optional)
        "loadNpmCommands": false, // Disable automatic npm commands
        "commands": [
            {
                "name": "▶️ Start USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "green",
                "command": "ha apps start local_ha_usbip_client"
            },
            {
                "name": "🛑 Stop USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "red",
                "command": "ha apps stop local_ha_usbip_client"
            },
            {
                "name": "🔄 Restart USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "blue",
                "command": "ha apps restart local_ha_usbip_client"
            },
            {
                "name": "🛠️ Rebuild USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "orange",
                "command": "ha apps rebuild local_ha_usbip_client"
            },
            {
                "name": "📦 Un/Install USBIP",
                "singleInstance": true,
                "focus": true,
                "color": "yellow",
                "command": "ha apps uninstall local_ha_usbip_client && ha apps install local_ha_usbip_client"
            },
            {
                "name": "📜 Logs USBIP (follow)",
                "singleInstance": true,
                "focus": true,
                "color": "brown",
                "command": "ha apps logs local_ha_usbip_client --follow"
            }
        ]
    },
    // NOTE: Configure `extraPaths` in `pyrightconfig.json` (do not set
    // `python.analysis.extraPaths` here when `pyrightconfig.json` is present)
    "python.defaultInterpreterPath": "/usr/bin/python3"
}